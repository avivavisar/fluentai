NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# CORS (comma-separated origins; "*" in dev)
CORS_ORIGIN="*"

# --- Supabase (Postgres + pgvector + Auth + Storage) ---
# Pooled connection (PgBouncer) used by the app at runtime:
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma Migrate (port 5432):
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
# Supabase project URL + keys (for Auth verification & Storage):
SUPABASE_URL="https://<ref>.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
# Used to verify Supabase Auth JWTs on the backend:
SUPABASE_JWT_SECRET=""

# --- Upstash (serverless Redis) ---
# Use the rediss:// (TLS) connection string from the Upstash console:
REDIS_URL=""

# --- AI / Speech ---
ANTHROPIC_API_KEY=""
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""
ELEVENLABS_API_KEY=""
