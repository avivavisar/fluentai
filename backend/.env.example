NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://fluentai:fluentai@localhost:5432/fluentai?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-to-a-long-random-secret-at-least-16-chars"
JWT_EXPIRES_IN="7d"

# CORS (use "*" in dev; lock to your app origin in prod)
CORS_ORIGIN="*"

# AI (required from Increment 1 onward)
ANTHROPIC_API_KEY=""

# Azure Speech (required from Increment 2 onward)
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""
