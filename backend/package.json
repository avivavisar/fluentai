    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
